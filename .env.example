# QuickBooks Online OAuth Credentials
# Get these from https://developer.intuit.com/app/developer/dashboard
QB_CLIENT_ID=your_client_id_here
QB_CLIENT_SECRET=your_client_secret_here
QB_REDIRECT_URI=http://localhost:3000/callback

# API key to protect the /mcp endpoint (required in production)
# Generate one with: node -e "console.log(crypto.randomUUID()+'-'+crypto.randomUUID())"
MCP_API_KEY=your-strong-api-key-here

# Railway API token for automatic token persistence (create at https://railway.com/account/tokens)
# Without this, refreshed tokens only live in memory and are lost on redeploy.
# RAILWAY_API_TOKEN=your_railway_api_token
# RAILWAY_PROJECT_ID, RAILWAY_SERVICE_ID, RAILWAY_ENVIRONMENT_ID are auto-injected by Railway

# QBO tokens (auto-managed by the server when RAILWAY_API_TOKEN is set)
# For first-time setup without Railway API, set manually after OAuth via /save-tokens
# QB_ACCESS_TOKEN=
# QB_REFRESH_TOKEN=
# QB_REALM_ID=
# QB_TOKEN_CREATED_AT=

# Server port (Railway sets this automatically)
PORT=3000

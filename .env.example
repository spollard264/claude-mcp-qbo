# QuickBooks Online OAuth Credentials
# Get these from https://developer.intuit.com/app/developer/dashboard
QB_CLIENT_ID=your_client_id_here
QB_CLIENT_SECRET=your_client_secret_here
QB_REDIRECT_URI=http://localhost:3000/callback

# API key to protect the /mcp endpoint (required in production)
# Generate one with: node -e "console.log(crypto.randomUUID()+'-'+crypto.randomUUID())"
MCP_API_KEY=your-strong-api-key-here

# Server port (Railway sets this automatically)
PORT=3000
